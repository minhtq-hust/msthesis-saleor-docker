        "id": 100,
        "title": "🏋️ Load Test Overview — Server-side throughput",
        "type": "row"
      },
      {
        "id": 1,
        "title": "Request Rate (server-side req/s)",
        "type": "stat",
        "gridPos": { "h": 4, "w": 6, "x": 0, "y": 1 },
        "transparent": true,
        "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
        "targets": [
          {
            "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
            "expr": "sum(rate(otel_traces_span_metrics_calls_total[1m]))",
            "refId": "A"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "color": { "mode": "thresholds" },
            "thresholds": {
              "mode": "absolute",
              "steps": [
                { "color": "#5794F2", "value": null },
                { "color": "#73BF69", "value": 1 },
                { "color": "#FF9830", "value": 50 }
              ]
            },
            "unit": "reqps", "decimals": 2,
            "mappings": [{ "type": "special", "options": { "match": "null", "result": { "text": "No traffic" } } }]
          }
        },
        "options": {
          "colorMode": "background", "graphMode": "area",
          "justifyMode": "center", "textMode": "auto",
          "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false }
        }
      },
      {
