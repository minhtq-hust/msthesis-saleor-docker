# ═══════════════════════════════════════════════════════════════════════════════
# Locust Load Test — Environment Configuration
# ═══════════════════════════════════════════════════════════════════════════════
# Copy to .env and adjust values before running.
# Values below are DEFAULTS — matching the original hardcoded settings.
#
# Usage:
#   source .env && SCENARIO=normal locust -f locustfile.py NormalLoadUser \
#     --users 100 --spawn-rate 7 --run-time 12m \
#     --host http://localhost:8000 --headless \
#     --csv=results/normal_baseline_run1

# ── Scenario ───────────────────────────────────────────────────────────────────
# "normal" | "flash_sale"
SCENARIO=normal

# ── Saleor Channel ─────────────────────────────────────────────────────────────
SALEOR_CHANNEL=default-channel

# ── Zipfian Locality ──────────────────────────────────────────────────────────
# α=1.0 → E[rank] ≈ 8.0 out of 32 products (Breslau et al., 1999)
# Higher α → more skewed toward top products
ZIPF_ALPHA=1.0

# ── Payment Gateway ────────────────────────────────────────────────────────────
# Saleor populatedb default dummy gateway
DUMMY_GATEWAY=mirumee.payments.dummy

# ═══════════════════════════════════════════════════════════════════════════════
# Think Time — Controls CCU/VU Ratio (Little's Law)
# ═══════════════════════════════════════════════════════════════════════════════
#
# CCU = VU × W_resp / (W_resp + W_think)
#
# Examples with VU=100, W_resp=0.2s:
#   W_think=4.0s → CCU ≈  5  (5%)   ← browsing behavior
#   W_think=2.0s → CCU ≈  9  (9%)   ← moderate engagement
#   W_think=1.0s → CCU ≈ 17  (17%)  ← decisive/flash-sale behavior
#   W_think=0.5s → CCU ≈ 29  (29%)  ← aggressive load
#
# ┌─────────────────────────────────────────────────────────────┐
# │ To increase CCU without adding VU → decrease think time.   │
# │ To decrease CCU without removing VU → increase think time. │
# └─────────────────────────────────────────────────────────────┘

# Normal scenario think time (seconds)
NORMAL_THINK_TIME=4.0

# Flash sale scenario think time (seconds)
FLASH_SALE_THINK_TIME=1.0

# ═══════════════════════════════════════════════════════════════════════════════
# Session Duration — Realistic User Session Lifecycle
# ═══════════════════════════════════════════════════════════════════════════════
#
# Each VU: connect → perform random tasks → disconnect after SESSION_DURATION.
# Locust auto-respawns a new VU to maintain --users target.
# Duration drawn from Uniform(SESSION_MIN, SESSION_MAX) per VU.
#
# Note: if a VU is mid-checkout when session expires, the checkout will
# complete before the VU disconnects (check happens BEFORE each new task).
#
# ┌─────────────────────────────────────────────────────────────┐
# │ Normal : avg session 120s (casual browsing, maybe 1 buy)   │
# │ Flash  : avg session 60s  (decisive, goal-oriented)        │
# └─────────────────────────────────────────────────────────────┘

NORMAL_SESSION_MIN=60
NORMAL_SESSION_MAX=180
FLASH_SESSION_MIN=30
FLASH_SESSION_MAX=90

# ═══════════════════════════════════════════════════════════════════════════════
# Flash Sale Shape — Traffic Curve Stages
# ═══════════════════════════════════════════════════════════════════════════════
# Each stage: DURATION_SEC,TARGET_USERS,SPAWN_RATE
#
# Scaled for 60 VU peak (2 uvicorn workers, PG max_connections=100)
#
# VU count
#  60 ─────────────────────┐
#           │  peak (meas) │
#  40 ──────┘              └──────
#  15 ──┘                        └──  8
#   0 ─────────────────────────────► time (min)
#       0   2   4         9  11  14
#
# Measurement window = minutes 4–9 (peak plateau)
#
# CCU at peak (60 VU, think=1.0s):
#   W_resp=0.5s (healthy)   → CCU ≈  20  (33%)
#   W_resp=2.0s (degraded)  → CCU ≈  40  (67%)
#   W_resp=5.0s (saturated) → CCU ≈  50  (83%)

FLASH_STAGE_1=120,15,3      # 0–2 min: warm up
FLASH_STAGE_2=240,40,8      # 2–4 min: ramp up  
FLASH_STAGE_3=540,60,5      # 4–9 min: peak → MEASUREMENT WINDOW
FLASH_STAGE_4=660,25,5      # 9–11 min: taper
FLASH_STAGE_5=840,8,2       # 11–14 min: cool down

# ═══════════════════════════════════════════════════════════════════════════════
# QUICK-START COMMANDS
# ═══════════════════════════════════════════════════════════════════════════════
#
# ── Normal Baseline ───────────────────────────────────────────────────────────
#   source .env
#   SCENARIO=normal locust -f locustfile.py NormalLoadUser \
#     --users 50 --spawn-rate 5 --run-time 12m --headless \
#     --host http://localhost:8000 --csv=results/normal_baseline_run1
#
# ── Flash Sale Baseline ──────────────────────────────────────────────────────
#   source .env
#   SCENARIO=flash_sale locust -f locustfile.py FlashSaleUser \
#     --host http://localhost:8000 --headless \
#     --csv=results/flash_baseline_run1
